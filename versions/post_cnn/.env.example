# Connection stringi do bazy Supabase (BeSafeFish)
# Skopiuj ten plik jako .env i wypelnij hasla
# cp .env.example .env
#
# Dane dostepowe (host, username) - zglos sie do @kamilkacperczyk
# Format: postgresql://USERNAME:HASLO@HOST:PORT/DATABASE

# Rola postgres (superuser) - uzywana wyjatkowo do DDL/administracji
DATABASE_URL_POSTGRES=postgresql://postgres.ID_PROJEKTU:TUTAJ_HASLO@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Rola admina - uzywana na co dzien
DATABASE_URL_ADMIN=postgresql://adm_kkacperczyk.ID_PROJEKTU:TUTAJ_HASLO@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
