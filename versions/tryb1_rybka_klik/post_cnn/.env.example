# Connection stringi do bazy Supabase (BeSafeFish)
# Skopiuj ten plik jako .env i wypelnij wartosci.
# cp .env.example .env
#
# Co podstawic:
#   ID_PROJEKTU = project ref z Dashboardu Supabase (Settings -> Database)
#   TUTAJ_HASLO = haslo roli ustawione w Supabase
#   adm_LOGIN   = nazwa Twojego usera admin (utworzonego przez supabase_migration.sql)
#   HOST        = z Dashboardu Supabase (Settings -> Database -> Connection pooling -> Session mode)
#                 format: aws-X-<region>.pooler.supabase.com
# Format: postgresql://USERNAME:HASLO@HOST:PORT/DATABASE

# Rola postgres (superuser) - uzywana wyjatkowo do DDL/administracji
DATABASE_URL_POSTGRES=postgresql://postgres.ID_PROJEKTU:TUTAJ_HASLO@HOST.pooler.supabase.com:5432/postgres

# Rola admina - uzywana na co dzien
DATABASE_URL_ADMIN=postgresql://adm_LOGIN.ID_PROJEKTU:TUTAJ_HASLO@HOST.pooler.supabase.com:5432/postgres
